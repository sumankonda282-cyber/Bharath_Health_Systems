# ──────────────────────────────────────────────────────────────────
# BharatCliniq v2 — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────────────────────────

# ── Database (Supabase PostgreSQL) ────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+psycopg2://postgres.dlewgbsfzlzcwovnnqhy:YOUR_SUPABASE_DB_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── Security ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── App ───────────────────────────────────────────────────────────
DEBUG=true
APP_VERSION=2.0.0

# ── CORS (comma-separated list of allowed origins) ───────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5175,https://bharatcliniq.com,https://www.bharatcliniq.com,https://provider.bharatcliniq.com,https://my.bharatcliniq.com,https://bharatcliniq-public.vercel.app,https://bharatcliniq-provider.vercel.app,https://bharatcliniq-patient.vercel.app

# ── OTP / SMS ────────────────────────────────────────────────────
# Set OTP_MOCK=true during development to skip real SMS
OTP_MOCK=true
SMS_PROVIDER=fast2sms          # "fast2sms" | "twilio"

# Fast2SMS (India)
FAST2SMS_API_KEY=

# Twilio (international / WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=            # E.164 e.g. +14155551234
TWILIO_WHATSAPP_FROM=          # whatsapp:+14155551234

# ── Email / SMTP ─────────────────────────────────────────────────
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
SMTP_USER=                     # e.g. notifications@bharathhealthsystems.com
SMTP_PASSWORD=                 # app password (not your Google account password)
EMAIL_FROM_ADDRESS=noreply@bharathhealthsystems.com
EMAIL_FROM_NAME=BHarath Health

# ── File Uploads ─────────────────────────────────────────────────
UPLOAD_DIR=uploads

# ── Subscription Plan Limits ──────────────────────────────────────
FREE_PLAN_MAX_DOCTORS=2
FREE_PLAN_MAX_BRANCHES=1

# ── Cloudinary (optional, for cloud image storage) ───────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
