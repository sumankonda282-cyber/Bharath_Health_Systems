# Never cache the HTML entry point — always serve the latest build
/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Hashed assets are safe to cache forever (filename changes with every build)
/assets/*
  Cache-Control: public, max-age=31536000, immutable
