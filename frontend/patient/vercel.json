{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "git": {
    "deploymentEnabled": {
      "claude/focused-wright-56yprs": false
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://bharatcliniq-api.onrender.com/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
